# Тестовые переменные окружения для SupplierFinder
# Скопируйте этот файл в .env.test и настройте под ваше окружение

# Тестовая база данных
TEST_DATABASE_URL=postgresql://test:test@localhost:5432/supplierfinder_test
DATABASE_URL=postgresql://test:test@localhost:5432/supplierfinder_test

# Тестовый порт
TEST_PORT=5001
PORT=5001

# Тестовые API ключи
TEST_OPENAI_API_KEY=test-openai-key
OPENAI_API_KEY=test-openai-key

TEST_SENDGRID_API_KEY=test-sendgrid-key
SENDGRID_API_KEY=test-sendgrid-key

# Тестовые настройки
NODE_ENV=test
ENABLE_EMAIL_CHECKING=false
SKIP_AUTH=false
ONBOARDING_ENABLED=true
VITE_ONBOARDING_ENABLED=true

# Тестовые настройки безопасности
SESSION_SECRET=test-session-secret-key-for-testing-only
CSRF_SECRET=test-csrf-secret-key-for-testing-only

# Тестовые настройки CORS
CORS_ORIGIN=http://localhost:5001

# Тестовые настройки rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=1000

# Тестовые настройки файлов
MAX_FILE_SIZE=15728640
UPLOAD_DIR=./test-uploads

# Тестовые настройки логирования
LOG_LEVEL=error
ENABLE_REQUEST_LOGGING=false

# Тестовые настройки производительности
ENABLE_PERFORMANCE_MONITORING=false
ENABLE_SLOW_QUERY_LOGGING=false



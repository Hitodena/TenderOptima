# 🔐 SupplierFinder Environment Variables
# Скопируйте этот файл в .env и заполните реальными значениями

# =============================================================================
# КРИТИЧЕСКИ ВАЖНЫЕ СЕКРЕТЫ (ОБЯЗАТЕЛЬНО В ПРОДАКШЕНЕ)
# =============================================================================

# Секрет для подписи JWT токенов (минимум 32 символа)
# Генерируйте случайную строку: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_SECRET=your-super-secret-token-key-here-minimum-32-characters

# Секрет для шифрования сессий (минимум 32 символа)
# Генерируйте случайную строку: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your-super-secret-session-key-here-minimum-32-characters

# =============================================================================
# НАСТРОЙКИ БАЗЫ ДАННЫХ
# =============================================================================

# URL подключения к PostgreSQL базе данных
DATABASE_URL=postgresql://username:password@localhost:5432/supplierfinder

# Альтернативные настройки БД (если не используете DATABASE_URL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=supplierfinder
DB_USER=postgres
DB_PASSWORD=your-database-password

# =============================================================================
# НАСТРОЙКИ EMAIL
# =============================================================================

# SMTP настройки для отправки email
SMTP_HOST=smtp.mail.ru
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-email-password

# Автоматическая проверка email каждые 2 минуты (true/false)
# Установите false для отключения во время разработки
ENABLE_EMAIL_CHECKING=true

# =============================================================================
# НАСТРОЙКИ ПРИЛОЖЕНИЯ
# =============================================================================

# Режим работы приложения
NODE_ENV=development

# Порт сервера
PORT=5000

# Разрешенные домены для CORS (через запятую)
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# =============================================================================
# НАСТРОЙКИ РАЗРАБОТКИ (ТОЛЬКО ДЛЯ DEV)
# =============================================================================

# ВНИМАНИЕ: НЕ ИСПОЛЬЗУЙТЕ В ПРОДАКШЕНЕ!
# DEV_MODE=true
# SKIP_AUTH=true

# =============================================================================
# ВНЕШНИЕ API
# =============================================================================

# DeepSeek API для анализа документов
DEEPSEEK_API_KEY=your-deepseek-api-key

# Google Search API
GOOGLE_SEARCH_API_TOKEN=your-google-api-token
GOOGLE_CUSTOM_SEARCH_ENGINE_ID=your-search-engine-id

# Yandex API
YANDEX_KEY_PATH=path/to/yandex/key
YANDEX_FOLDER_ID=your-yandex-folder-id

# =============================================================================
# БЕЗОПАСНОСТЬ
# =============================================================================

# ВНИМАНИЕ: 
# 1. Никогда не коммитьте .env файл в Git
# 2. Используйте разные секреты для разных окружений
# 3. Регулярно меняйте секреты
# 4. Используйте сильные пароли (минимум 32 символа)
# 5. В продакшене используйте переменные окружения сервера

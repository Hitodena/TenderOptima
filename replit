modules = ["python-3.11", "postgresql-16", "nodejs-20", "python3"]

[nix]
channel = "stable-24_05"
packages = ["chromium", "file", "freetype", "gitFull", "glibcLocales", "gmp", "jq", "lcms2", "libimagequant", "libjpeg", "libtiff", "libwebp", "libxcrypt", "openjpeg", "playwright-driver", "poppler", "poppler_utils", "rsync", "tcl", "tesseract", "tk", "xcodebuild", "zlib"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "SupplierFinder Setup"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "SupplierFinder"

[[workflows.workflow]]
name = "SupplierFinder Setup"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python modified_setup.py"

[[workflows.workflow]]
name = "SupplierFinder"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd SupplierFinder && npm run dev:unified"
waitForPort = 5000

[deployment]
run = ["sh", "-c", "python setup.py"]

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 5001
externalPort = 80

[agent]
expertMode = true

[[workflows.workflow]]
name = "Run Python Parser"
# Эта задача запустит ваш FastAPI сервер
[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd SupplierFinder && uvicorn main:app --host 0.0.0.0 --port 8080 --reload"
waitForPort = 8080


{
	"openapi": "3.1.0",
	"info": { "title": "FastAPI", "version": "0.1.0" },
	"paths": {
		"/api/auth/register": {
			"post": {
				"tags": ["Auth"],
				"summary": "Register a new user account",
				"description": "Creates a new user record. Returns a JWT access token on success. Fails\nwith 409 if the email is already registered.",
				"operationId": "register_api_auth_register_post",
				"requestBody": {
					"content": {
						"application/json": {
							"schema": { "$ref": "#/components/schemas/RegisterCreate" }
						}
					},
					"required": true
				},
				"responses": {
					"201": {
						"description": "User successfully created and JWT returned",
						"content": {
							"application/json": {
								"schema": { "$ref": "#/components/schemas/TokenResponse" }
							}
						}
					},
					"409": { "description": "Email already exists in the system" },
					"422": { "description": "Validation error in request payload" }
				}
			}
		},
		"/api/auth/token": {
			"post": {
				"tags": ["Auth"],
				"summary": "Authenticate user and obtain JWT",
				"description": "OAuth2 password flow login. Returns JWT on successful credential\nvalidation.",
				"operationId": "login_api_auth_token_post",
				"requestBody": {
					"content": {
						"application/x-www-form-urlencoded": {
							"schema": {
								"$ref": "#/components/schemas/Body_login_api_auth_token_post"
							}
						}
					},
					"required": true
				},
				"responses": {
					"200": {
						"description": "Authentication successful, JWT returned",
						"content": {
							"application/json": {
								"schema": { "$ref": "#/components/schemas/TokenResponse" }
							}
						}
					},
					"401": { "description": "Invalid credentials provided" },
					"422": { "description": "Invalid form data" }
				}
			}
		},
		"/api/auth/me": {
			"get": {
				"tags": ["Auth"],
				"summary": "Retrieve current authenticated user",
				"description": "Returns profile data for the currently authenticated user using the\nprovided JWT.",
				"operationId": "get_user_api_auth_me_get",
				"responses": {
					"200": {
						"description": "Current user profile returned",
						"content": {
							"application/json": {
								"schema": { "$ref": "#/components/schemas/UserResponse" }
							}
						}
					},
					"401": { "description": "Missing or invalid JWT" }
				},
				"security": [{ "OAuth2PasswordBearer": [] }]
			}
		},
		"/api/requests/": {
			"get": {
				"tags": ["Requests"],
				"summary": "List all requests for the current user",
				"description": "Returns all requests created by the authenticated user.",
				"operationId": "get_requests_api_requests__get",
				"responses": {
					"200": {
						"description": "List of all requests belonging to the user",
						"content": {
							"application/json": {
								"schema": {
									"items": { "$ref": "#/components/schemas/RequestResponse" },
									"type": "array",
									"title": "Response Get Requests Api Requests  Get"
								}
							}
						}
					},
					"401": {
						"description": "Missing or invalid authentication credentials"
					}
				},
				"security": [{ "OAuth2PasswordBearer": [] }]
			},
			"post": {
				"tags": ["Requests"],
				"summary": "Create a new supplier search request",
				"description": "Creates a new request in 'draft' status. The request can later be searched and mailed.",
				"operationId": "create_request_api_requests__post",
				"requestBody": {
					"content": {
						"application/json": {
							"schema": { "$ref": "#/components/schemas/RequestCreate" }
						}
					},
					"required": true
				},
				"responses": {
					"201": {
						"description": "Request successfully created in draft status",
						"content": {
							"application/json": {
								"schema": { "$ref": "#/components/schemas/RequestResponse" }
							}
						}
					},
					"401": {
						"description": "Missing or invalid authentication credentials"
					},
					"422": { "description": "Validation error in request payload" }
				},
				"security": [{ "OAuth2PasswordBearer": [] }]
			}
		},
		"/api/requests/{request_id}/search": {
			"post": {
				"tags": ["Requests"],
				"summary": "Search for suppliers and save results",
				"description": "Runs an external parser search, filters blacklisted domains, and saves valid suppliers.",
				"operationId": "search_suppliers_api_requests__request_id__search_post",
				"security": [{ "OAuth2PasswordBearer": [] }],
				"parameters": [
					{
						"name": "request_id",
						"in": "path",
						"required": true,
						"schema": {
							"type": "string",
							"format": "uuid",
							"title": "Request Id"
						}
					}
				],
				"responses": {
					"200": {
						"description": "Search completed and suppliers saved",
						"content": {
							"application/json": {
								"schema": { "$ref": "#/components/schemas/SearchResult" }
							}
						}
					},
					"400": { "description": "Request is not in a searchable state" },
					"401": {
						"description": "Missing or invalid authentication credentials"
					},
					"404": {
						"description": "Request not found or does not belong to user"
					},
					"502": { "description": "External parser service unavailable" },
					"422": {
						"description": "Validation Error",
						"content": {
							"application/json": {
								"schema": { "$ref": "#/components/schemas/HTTPValidationError" }
							}
						}
					}
				}
			}
		},
		"/api/requests/{request_id}/launch": {
			"post": {
				"tags": ["Requests"],
				"summary": "Queue email campaign for a request",
				"description": "Queues a background task to send emails to all pending suppliers for this request.",
				"operationId": "launch_mailing_api_requests__request_id__launch_post",
				"security": [{ "OAuth2PasswordBearer": [] }],
				"parameters": [
					{
						"name": "request_id",
						"in": "path",
						"required": true,
						"schema": {
							"type": "string",
							"format": "uuid",
							"title": "Request Id"
						}
					}
				],
				"responses": {
					"202": {
						"description": "Mailing task successfully queued",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/LaunchMailingResponse"
								}
							}
						}
					},
					"400": {
						"description": "Request not in active state or no pending suppliers"
					},
					"401": {
						"description": "Missing or invalid authentication credentials"
					},
					"404": {
						"description": "Request not found or does not belong to user"
					},
					"422": {
						"description": "Validation Error",
						"content": {
							"application/json": {
								"schema": { "$ref": "#/components/schemas/HTTPValidationError" }
							}
						}
					}
				}
			}
		},
		"/api/requests/{request_id}": {
			"get": {
				"tags": ["Requests"],
				"summary": "Retrieve a single request by ID",
				"description": "Fetches a specific request if it belongs to the current user.",
				"operationId": "get_request_api_requests__request_id__get",
				"security": [{ "OAuth2PasswordBearer": [] }],
				"parameters": [
					{
						"name": "request_id",
						"in": "path",
						"required": true,
						"schema": {
							"type": "string",
							"format": "uuid",
							"title": "Request Id"
						}
					}
				],
				"responses": {
					"200": {
						"description": "Request details returned",
						"content": {
							"application/json": {
								"schema": { "$ref": "#/components/schemas/RequestResponse" }
							}
						}
					},
					"401": {
						"description": "Missing or invalid authentication credentials"
					},
					"404": {
						"description": "Request not found or does not belong to user"
					},
					"422": {
						"description": "Validation Error",
						"content": {
							"application/json": {
								"schema": { "$ref": "#/components/schemas/HTTPValidationError" }
							}
						}
					}
				}
			}
		},
		"/api/requests/{request_id}/responses": {
			"get": {
				"tags": ["Requests"],
				"summary": "List supplier responses for a request",
				"description": "Returns all supplier email responses associated with the given request.",
				"operationId": "get_responses_api_requests__request_id__responses_get",
				"security": [{ "OAuth2PasswordBearer": [] }],
				"parameters": [
					{
						"name": "request_id",
						"in": "path",
						"required": true,
						"schema": {
							"type": "string",
							"format": "uuid",
							"title": "Request Id"
						}
					}
				],
				"responses": {
					"200": {
						"description": "List of email responses received from suppliers",
						"content": {
							"application/json": {
								"schema": {
									"type": "array",
									"items": {
										"$ref": "#/components/schemas/SupplierResponseResponse"
									},
									"title": "Response Get Responses Api Requests  Request Id  Responses Get"
								}
							}
						}
					},
					"401": {
						"description": "Missing or invalid authentication credentials"
					},
					"404": {
						"description": "Request not found or does not belong to user"
					},
					"422": {
						"description": "Validation Error",
						"content": {
							"application/json": {
								"schema": { "$ref": "#/components/schemas/HTTPValidationError" }
							}
						}
					}
				}
			}
		},
		"/api/blacklist/": {
			"get": {
				"tags": ["Blacklisted Domains"],
				"summary": "List all blacklisted domains for the current user",
				"description": "Returns all domains blacklisted by the currently authenticated user.",
				"operationId": "get_blacklist_api_blacklist__get",
				"responses": {
					"200": {
						"description": "List of blacklisted domains belonging to the authenticated user",
						"content": {
							"application/json": {
								"schema": {
									"items": { "$ref": "#/components/schemas/BlacklistResponse" },
									"type": "array",
									"title": "Response Get Blacklist Api Blacklist  Get"
								}
							}
						}
					},
					"401": {
						"description": "Missing or invalid authentication credentials"
					}
				},
				"security": [{ "OAuth2PasswordBearer": [] }]
			},
			"post": {
				"tags": ["Blacklisted Domains"],
				"summary": "Add a new domain to the blacklist",
				"description": "Adds a domain to the current user's blacklist.\nThe domain is normalized (lowercased and stripped).",
				"operationId": "add_to_blacklist_api_blacklist__post",
				"requestBody": {
					"content": {
						"application/json": {
							"schema": { "$ref": "#/components/schemas/BlacklistCreate" }
						}
					},
					"required": true
				},
				"responses": {
					"201": {
						"description": "Domain successfully added to the blacklist",
						"content": {
							"application/json": {
								"schema": { "$ref": "#/components/schemas/BlacklistResponse" }
							}
						}
					},
					"401": {
						"description": "Missing or invalid authentication credentials"
					},
					"422": { "description": "Validation error in request payload" }
				},
				"security": [{ "OAuth2PasswordBearer": [] }]
			}
		},
		"/api/blacklist/{domain_id}": {
			"delete": {
				"tags": ["Blacklisted Domains"],
				"summary": "Remove a domain from the blacklist",
				"description": "Deletes a specific blacklist entry if it belongs to the current user.",
				"operationId": "remove_from_blacklist_api_blacklist__domain_id__delete",
				"security": [{ "OAuth2PasswordBearer": [] }],
				"parameters": [
					{
						"name": "domain_id",
						"in": "path",
						"required": true,
						"schema": {
							"type": "string",
							"format": "uuid",
							"title": "Domain Id"
						}
					}
				],
				"responses": {
					"204": {
						"description": "Domain successfully removed from the blacklist"
					},
					"401": {
						"description": "Missing or invalid authentication credentials"
					},
					"404": {
						"description": "Domain not found or does not belong to the current user"
					},
					"422": {
						"description": "Validation Error",
						"content": {
							"application/json": {
								"schema": { "$ref": "#/components/schemas/HTTPValidationError" }
							}
						}
					}
				}
			}
		},
		"/api/history/": {
			"get": {
				"tags": ["Search history"],
				"summary": "Retrieve search history for the current user",
				"description": "Returns all search history entries belonging to the current user, ordered by creation time.",
				"operationId": "get_search_history_api_history__get",
				"responses": {
					"200": {
						"description": "List of past searches performed by the authenticated user",
						"content": {
							"application/json": {
								"schema": {
									"items": {
										"$ref": "#/components/schemas/SearchHistoryResponse"
									},
									"type": "array",
									"title": "Response Get Search History Api History  Get"
								}
							}
						}
					},
					"401": {
						"description": "Missing or invalid authentication credentials"
					}
				},
				"security": [{ "OAuth2PasswordBearer": [] }]
			}
		},
		"/api/": {
			"get": {
				"summary": "Root",
				"operationId": "root_api__get",
				"responses": {
					"200": {
						"description": "Successful Response",
						"content": { "application/json": { "schema": {} } }
					}
				}
			}
		},
		"/api/health": {
			"get": {
				"summary": "Health",
				"operationId": "health_api_health_get",
				"responses": {
					"200": {
						"description": "Successful Response",
						"content": {
							"application/json": {
								"schema": {
									"additionalProperties": true,
									"type": "object",
									"title": "Response Health Api Health Get"
								}
							}
						}
					}
				}
			}
		}
	},
	"components": {
		"schemas": {
			"Attachment": {
				"properties": {
					"filename": {
						"type": "string",
						"title": "Filename",
						"description": "Original filename of the attachment",
						"examples": ["quote.pdf"]
					},
					"content_type": {
						"anyOf": [{ "type": "string" }, { "type": "null" }],
						"title": "Content Type",
						"description": "MIME type of the file",
						"examples": ["application/pdf"]
					},
					"size": {
						"anyOf": [{ "type": "integer" }, { "type": "null" }],
						"title": "Size",
						"description": "File size in bytes",
						"examples": [245678]
					},
					"path": {
						"anyOf": [{ "type": "string" }, { "type": "null" }],
						"title": "Path",
						"description": "Server path where the file is stored",
						"examples": ["/uploads/attachments/quote.pdf"]
					}
				},
				"type": "object",
				"required": ["filename", "content_type", "size", "path"],
				"title": "Attachment",
				"description": "Email attachment metadata."
			},
			"BlacklistCreate": {
				"properties": {
					"domain": {
						"type": "string",
						"maxLength": 255,
						"minLength": 3,
						"title": "Domain",
						"description": "Domain name to blacklist (will be lowercased and stripped)",
						"examples": ["example.com"]
					},
					"reason": {
						"anyOf": [
							{ "type": "string", "maxLength": 500 },
							{ "type": "null" }
						],
						"title": "Reason",
						"description": "Optional reason for blacklisting the domain",
						"examples": ["Spam source"]
					}
				},
				"type": "object",
				"required": ["domain"],
				"title": "BlacklistCreate",
				"description": "Payload for adding a domain to the blacklist."
			},
			"BlacklistResponse": {
				"properties": {
					"id": {
						"type": "string",
						"format": "uuid",
						"title": "Id",
						"description": "Unique identifier of the blacklist entry",
						"examples": ["123e4567-e89b-12d3-a456-426614174000"]
					},
					"domain": {
						"type": "string",
						"title": "Domain",
						"description": "The blacklisted domain name",
						"examples": ["example.com"]
					},
					"reason": {
						"anyOf": [{ "type": "string" }, { "type": "null" }],
						"title": "Reason",
						"description": "Reason provided when the domain was blacklisted",
						"examples": ["Spam source"]
					},
					"created_at": {
						"type": "string",
						"format": "date-time",
						"title": "Created At",
						"description": "Timestamp when the entry was created",
						"examples": ["2025-01-15T10:30:00Z"]
					}
				},
				"type": "object",
				"required": ["id", "domain", "reason", "created_at"],
				"title": "BlacklistResponse",
				"description": "Representation of a blacklisted domain record."
			},
			"Body_login_api_auth_token_post": {
				"properties": {
					"grant_type": {
						"anyOf": [
							{ "type": "string", "pattern": "^password$" },
							{ "type": "null" }
						],
						"title": "Grant Type"
					},
					"username": { "type": "string", "title": "Username" },
					"password": {
						"type": "string",
						"format": "password",
						"title": "Password"
					},
					"scope": { "type": "string", "title": "Scope", "default": "" },
					"client_id": {
						"anyOf": [{ "type": "string" }, { "type": "null" }],
						"title": "Client Id"
					},
					"client_secret": {
						"anyOf": [{ "type": "string" }, { "type": "null" }],
						"format": "password",
						"title": "Client Secret"
					}
				},
				"type": "object",
				"required": ["username", "password"],
				"title": "Body_login_api_auth_token_post"
			},
			"HTTPValidationError": {
				"properties": {
					"detail": {
						"items": { "$ref": "#/components/schemas/ValidationError" },
						"type": "array",
						"title": "Detail"
					}
				},
				"type": "object",
				"title": "HTTPValidationError"
			},
			"LaunchMailingResponse": {
				"properties": {
					"status": {
						"type": "string",
						"title": "Status",
						"description": "Task status",
						"examples": ["queued"]
					},
					"request_id": {
						"type": "string",
						"title": "Request Id",
						"description": "ID of the request",
						"examples": ["123e4567-e89b-12d3-a456-426614174000"]
					},
					"pending": {
						"type": "integer",
						"title": "Pending",
						"description": "Number of pending suppliers",
						"examples": [5]
					}
				},
				"type": "object",
				"required": ["status", "request_id", "pending"],
				"title": "LaunchMailingResponse",
				"description": "Response when a mailing campaign is successfully queued."
			},
			"RegisterCreate": {
				"properties": {
					"email": {
						"type": "string",
						"format": "email",
						"title": "Email",
						"description": "Valid email address used as unique user identifier",
						"examples": ["user@example.com"]
					},
					"password": {
						"type": "string",
						"maxLength": 128,
						"minLength": 8,
						"title": "Password",
						"description": "Plain-text password (will be hashed server-side)",
						"examples": ["SecurePass123!"]
					},
					"full_name": {
						"anyOf": [
							{ "type": "string", "maxLength": 100, "minLength": 2 },
							{ "type": "null" }
						],
						"title": "Full Name",
						"description": "Optional full legal name of the user",
						"examples": ["John Doe"]
					},
					"company_name": {
						"anyOf": [
							{ "type": "string", "maxLength": 150, "minLength": 2 },
							{ "type": "null" }
						],
						"title": "Company Name",
						"description": "Optional company or organization name",
						"examples": ["Acme Corp"]
					}
				},
				"type": "object",
				"required": ["email", "password"],
				"title": "RegisterCreate",
				"description": "User registration payload."
			},
			"RequestCreate": {
				"properties": {
					"query": {
						"type": "string",
						"maxLength": 500,
						"minLength": 3,
						"title": "Query",
						"description": "Main search query describing the product needed",
						"examples": ["industrial pumps"]
					},
					"delivery_region": {
						"anyOf": [
							{ "type": "string", "maxLength": 100 },
							{ "type": "null" }
						],
						"title": "Delivery Region",
						"description": "Preferred delivery region or country",
						"examples": ["Minsk"]
					},
					"description": {
						"anyOf": [
							{ "type": "string", "maxLength": 2000 },
							{ "type": "null" }
						],
						"title": "Description",
						"description": "Detailed description of requirements",
						"examples": ["High pressure centrifugal pumps"]
					},
					"quantity": {
						"anyOf": [
							{ "type": "number", "exclusiveMinimum": 0.0 },
							{ "type": "null" }
						],
						"title": "Quantity",
						"description": "Requested quantity",
						"examples": [100]
					},
					"unit": {
						"anyOf": [
							{ "type": "string", "maxLength": 50 },
							{ "type": "null" }
						],
						"title": "Unit",
						"description": "Unit of measurement",
						"examples": ["pcs"]
					},
					"quality_requirements": {
						"anyOf": [
							{ "type": "string", "maxLength": 1000 },
							{ "type": "null" }
						],
						"title": "Quality Requirements",
						"description": "Specific quality or certification requirements",
						"examples": ["ISO 9001 certified"]
					},
					"delivery_deadline": {
						"anyOf": [
							{ "type": "string", "format": "date-time" },
							{ "type": "null" }
						],
						"title": "Delivery Deadline",
						"description": "Latest acceptable delivery date"
					},
					"max_price_per_unit": {
						"anyOf": [
							{ "type": "number" },
							{
								"type": "string",
								"pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$"
							},
							{ "type": "null" }
						],
						"title": "Max Price Per Unit",
						"description": "Maximum acceptable price per unit",
						"examples": [1000]
					},
					"currency": {
						"anyOf": [
							{ "type": "string", "maxLength": 20, "minLength": 2 },
							{ "type": "null" }
						],
						"title": "Currency",
						"description": "Currency code for the price",
						"default": "BYN",
						"examples": ["BYN"]

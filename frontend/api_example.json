{
	"openapi": "3.1.0",
	"info": { "title": "FastAPI", "version": "0.1.0" },
	"paths": {
		"/api/auth/register": {
			"post": {
				"tags": ["Auth"],
				"summary": "Register a new user account",
				"description": "Creates a new user record. Returns a JWT access token on success. Fails\nwith 409 if the email is already registered.",
				"operationId": "register_api_auth_register_post",
				"requestBody": {
					"content": {
						"application/json": {
							"schema": { "$ref": "#/components/schemas/RegisterCreate" }
						}
					},
					"required": true
				},
				"responses": {
					"201": {
						"description": "User successfully created and JWT returned",
						"content": {
							"application/json": {
								"schema": { "$ref": "#/components/schemas/TokenResponse" }
							}
						}
					},
					"409": { "description": "Email already exists in the system" },
					"422": { "description": "Validation error in request payload" }
				}
			}
		},
		"/api/auth/token": {
			"post": {
				"tags": ["Auth"],
				"summary": "Authenticate user and obtain JWT",
				"description": "OAuth2 password flow login. Returns JWT on successful credential\nvalidation.",
				"operationId": "login_api_auth_token_post",
				"requestBody": {
					"content": {
						"application/x-www-form-urlencoded": {
							"schema": {
								"$ref": "#/components/schemas/Body_login_api_auth_token_post"
							}
						}
					},
					"required": true
				},
				"responses": {
					"200": {
						"description": "Authentication successful, JWT returned",
						"content": {
							"application/json": {
								"schema": { "$ref": "#/components/schemas/TokenResponse" }
							}
						}
					},
					"401": { "description": "Invalid credentials provided" },
					"422": { "description": "Invalid form data" }
				}
			}
		},
		"/api/auth/me": {
			"get": {
				"tags": ["Auth"],
				"summary": "Retrieve current authenticated user",
				"description": "Returns profile data for the currently authenticated user using the\nprovided JWT.",
				"operationId": "get_user_api_auth_me_get",
				"responses": {
					"200": {
						"description": "Current user profile returned",
						"content": {
							"application/json": {
								"schema": { "$ref": "#/components/schemas/UserResponse" }
							}
						}
					},
					"401": { "description": "Missing or invalid JWT" }
				},
				"security": [{ "OAuth2PasswordBearer": [] }]
			}
		},
		"/api/requests/": {
			"get": {
				"tags": ["Requests"],
				"summary": "List all requests for the current user",
				"description": "Returns all requests created by the authenticated user.",
				"operationId": "get_requests_api_requests__get",
				"responses": {
					"200": {
						"description": "List of all requests belonging to the user",
						"content": {
							"application/json": {
								"schema": {
									"items": { "$ref": "#/components/schemas/RequestResponse" },
									"type": "array",
									"title": "Response Get Requests Api Requests  Get"
								}
							}
						}
					},
					"401": {
						"description": "Missing or invalid authentication credentials"
					}
				},
				"security": [{ "OAuth2PasswordBearer": [] }]
			},
			"post": {
				"tags": ["Requests"],
				"summary": "Create a new supplier search request",
				"description": "Creates a new request in 'draft' status. The request can later be searched and mailed.",
				"operationId": "create_request_api_requests__post",
				"requestBody": {
					"content": {
						"application/json": {
							"schema": { "$ref": "#/components/schemas/RequestCreate" }
						}
					},
					"required": true
				},
				"responses": {
					"201": {
						"description": "Request successfully created in draft status",
						"content": {
							"application/json": {
								"schema": { "$ref": "#/components/schemas/RequestResponse" }
							}
						}
					},
					"401": {
						"description": "Missing or invalid authentication credentials"
					},
					"422": { "description": "Validation error in request payload" }
				},
				"security": [{ "OAuth2PasswordBearer": [] }]
			}
		},
		"/api/requests/{request_id}/search": {
			"post": {
				"tags": ["Requests"],
				"summary": "Search for suppliers and save results",
				"description": "Runs an external parser search, filters blacklisted domains, and saves valid suppliers.",
				"operationId": "search_suppliers_api_requests__request_id__search_post",
				"security": [{ "OAuth2PasswordBearer": [] }],
				"parameters": [
					{
						"name": "request_id",
						"in": "path",
						"required": true,
						"schema": {
							"type": "string",
							"format": "uuid",
							"title": "Request Id"
						}
					}
				],
				"responses": {
					"200": {
						"description": "Search completed and suppliers saved",
						"content": {
							"application/json": {
								"schema": { "$ref": "#/components/schemas/SearchResult" }
							}
						}
					},
					"400": { "description": "Request is not in a searchable state" },
					"401": {
						"description": "Missing or invalid authentication credentials"
					},
					"404": {
						"description": "Request not found or does not belong to user"
					},
					"502": { "description": "External parser service unavailable" },
					"422": {
						"description": "Validation Error",
						"content": {
							"application/json": {
								"schema": { "$ref": "#/components/schemas/HTTPValidationError" }
							}
						}
					}
				}
			}
		},
		"/api/requests/{request_id}/launch": {
			"post": {
				"tags": ["Requests"],
				"summary": "Queue email campaign for a request",
				"description": "Queues a background task to send emails to all pending suppliers for this request.",
				"operationId": "launch_mailing_api_requests__request_id__launch_post",
				"security": [{ "OAuth2PasswordBearer": [] }],
				"parameters": [
					{
						"name": "request_id",
						"in": "path",
						"required": true,
						"schema": {
							"type": "string",
							"format": "uuid",
							"title": "Request Id"
						}
					}
				],
				"responses": {
					"202": {
						"description": "Mailing task successfully queued",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/LaunchMailingResponse"
								}
							}
						}
					},
					"400": {
						"description": "Request not in active state or no pending suppliers"
					},
					"401": {
						"description": "Missing or invalid authentication credentials"
					},
					"404": {
						"description": "Request not found or does not belong to user"
					},
					"422": {
						"description": "Validation Error",
						"content": {
							"application/json": {
								"schema": { "$ref": "#/components/schemas/HTTPValidationError" }
							}
						}
					}
				}
			}
		},
		"/api/requests/{request_id}": {
			"get": {
				"tags": ["Requests"],
				"summary": "Retrieve a single request by ID",
				"description": "Fetches a specific request if it belongs to the current user.",
				"operationId": "get_request_api_requests__request_id__get",
				"security": [{ "OAuth2PasswordBearer": [] }],
				"parameters": [
					{
						"name": "request_id",
						"in": "path",
						"required": true,
						"schema": {
							"type": "string",
							"format": "uuid",
							"title": "Request Id"
						}
					}
				],
				"responses": {
					"200": {
						"description": "Request details returned",
						"content": {
							"application/json": {
								"schema": { "$ref": "#/components/schemas/RequestResponse" }
							}
						}
					},
					"401": {
						"description": "Missing or invalid authentication credentials"
					},
					"404": {
						"description": "Request not found or does not belong to user"
					},
					"422": {
						"description": "Validation Error",
						"content": {
							"application/json": {
								"schema": { "$ref": "#/components/schemas/HTTPValidationError" }
							}
						}
					}
				}
			},
			"patch": {
				"tags": ["Requests"],
				"summary": "Update optional fields and additional parameters for the request email",
				"description": "Updates description, additional_params JSON",
				"operationId": "update_request_additional_params_api_requests__request_id__patch",
				"security": [{ "OAuth2PasswordBearer": [] }],
				"parameters": [
					{
						"name": "request_id",
						"in": "path",
						"required": true,
						"schema": {
							"type": "string",
							"format": "uuid",
							"title": "Request Id"
						}
					}
				],
				"requestBody": {
					"required": true,
					"content": {
						"application/json": {
							"schema": { "$ref": "#/components/schemas/RequestUpdate" }
						}
					}
				},
				"responses": {
					"200": {
						"description": "Request parameters updated",
						"content": {
							"application/json": {
								"schema": { "$ref": "#/components/schemas/RequestResponse" }
							}
						}
					},
					"401": {
						"description": "Missing or invalid authentication credentials"
					},
					"404": {
						"description": "Request not found or does not belong to user"
					},
					"422": { "description": "Validation Error" }
				}
			}
		},
		"/api/requests/{request_id}/responses": {
			"get": {
				"tags": ["Requests"],
				"summary": "List supplier responses for a request",
				"description": "Returns all supplier email responses associated with the given request.",
				"operationId": "get_responses_api_requests__request_id__responses_get",
				"security": [{ "OAuth2PasswordBearer": [] }],
				"parameters": [
					{
						"name": "request_id",
						"in": "path",
						"required": true,
						"schema": {
							"type": "string",
							"format": "uuid",
							"title": "Request Id"
						}
					}
				],
				"responses": {
					"200": {
						"description": "List of email responses received from suppliers",
						"content": {
							"application/json": {
								"schema": {
									"type": "array",
									"items": {
										"$ref": "#/components/schemas/SupplierResponseResponse"
									},
									"title": "Response Get Responses Api Requests  Request Id  Responses Get"
								}
							}
						}
					},
					"401": {
						"description": "Missing or invalid authentication credentials"
					},
					"404": {
						"description": "Request not found or does not belong to user"
					},
					"422": {
						"description": "Validation Error",
						"content": {
							"application/json": {
								"schema": { "$ref": "#/components/schemas/HTTPValidationError" }
							}
						}
					}
				}
			}
		},
		"/api/requests/{request_id}/suppliers": {
			"get": {
				"tags": ["Requests"],
				"summary": "List suppliers for a request",
				"description": "Returns all suppliers associated with the given request.",
				"operationId": "get_suppliers_api_requests__request_id__suppliers_get",
				"security": [{ "OAuth2PasswordBearer": [] }],
				"parameters": [
					{
						"name": "request_id",
						"in": "path",
						"required": true,
						"schema": {
							"type": "string",
							"format": "uuid",
							"title": "Request Id"
						}
					}
				],
				"responses": {
					"200": {
						"description": "List of suppliers associated with the request",
						"content": {
							"application/json": {
								"schema": {
									"type": "array",
									"items": {
										"$ref": "#/components/schemas/RequestSupplierResponse"
									},
									"title": "Response Get Suppliers Api Requests  Request Id  Suppliers Get"
								}
							}
						}
					},
					"401": {
						"description": "Missing or invalid authentication credentials"
					},
					"404": {
						"description": "Request not found or does not belong to user"
					},
					"422": {
						"description": "Validation Error",
						"content": {
							"application/json": {
								"schema": { "$ref": "#/components/schemas/HTTPValidationError" }
							}
						}
					}
				}
			}
		},
		"/api/requests/{request_id}/suppliers/{request_supplier_id}": {
			"patch": {
				"tags": ["Requests"],
				"summary": "Toggle supplier enabled status for a request",
				"description": "Updates the enabled status of a supplier for a specific request.",
				"operationId": "toggle_supplier_api_requests__request_id__suppliers__request_supplier_id__patch",
				"security": [{ "OAuth2PasswordBearer": [] }],
				"parameters": [
					{
						"name": "request_id",
						"in": "path",
						"required": true,
						"schema": {
							"type": "string",
							"format": "uuid",
							"title": "Request Id"
						}
					},
					{
						"name": "request_supplier_id",
						"in": "path",
						"required": true,
						"schema": {
							"type": "string",
							"format": "uuid",
							"title": "Request Supplier Id"
						}
					}
				],
				"requestBody": {
					"required": true,
					"content": {
						"application/json": {
							"schema": { "$ref": "#/components/schemas/ToggleSupplierRequest" }
						}
					}
				},
				"responses": {
					"200": {
						"description": "Supplier enabled status updated",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/RequestSupplierResponse"
								}
							}
						}
					},
					"401": {
						"description": "Missing or invalid authentication credentials"
					},
					"404": { "description": "Request or supplier not found" },
					"422": {
						"description": "Validation Error",
						"content": {
							"application/json": {
								"schema": { "$ref": "#/components/schemas/HTTPValidationError" }
							}
						}
					}
				}
			}
		},
		"/api/requests/{request_id}/email_message": {
			"patch": {
				"tags": ["Requests"],
				"summary": "Update email message for a request",
				"description": "Updates the generated email message for the request.",
				"operationId": "update_request_email_message_api_requests__request_id__email_message_patch",
				"security": [{ "OAuth2PasswordBearer": [] }],
				"parameters": [
					{
						"name": "request_id",
						"in": "path",
						"required": true,
						"schema": {
							"type": "string",
							"format": "uuid",
							"title": "Request Id"
						}
					}
				],
				"responses": {
					"200": {
						"description": "Email message updated",
						"content": {
							"application/json": {
								"schema": { "$ref": "#/components/schemas/RequestResponse" }
							}
						}
					},
					"401": {
						"description": "Missing or invalid authentication credentials"
					},
					"404": {
						"description": "Request not found or does not belong to user"
					},
					"422": { "description": "Validation Error" }
				}
			}
		},
		"/api/blacklist/": {
			"get": {
				"tags": ["Blacklisted Domains"],
				"summary": "List all blacklisted domains for the current user",
				"description": "Returns all domains blacklisted by the currently authenticated user.",
				"operationId": "get_blacklist_api_blacklist__get",
				"responses": {
					"200": {
						"description": "List of blacklisted domains belonging to the authenticated user",
						"content": {
							"application/json": {
								"schema": {
									"items": { "$ref": "#/components/schemas/BlacklistResponse" },
									"type": "array",
									"title": "Response Get Blacklist Api Blacklist  Get"
								}
							}
						}
					},
					"401": {
						"description": "Missing or invalid authentication credentials"
					}
				},
				"security": [{ "OAuth2PasswordBearer": [] }]
			},
			"post": {
				"tags": ["Blacklisted Domains"],
				"summary": "Add a new domain to the blacklist",
				"description": "Adds a domain to the current user's blacklist.\nThe domain is normalized (lowercased and stripped).",
				"operationId": "add_to_blacklist_api_blacklist__post",
				"requestBody": {
					"content": {
						"application/json": {
							"schema": { "$ref": "#/components/schemas/BlacklistCreate" }
						}
					},
					"required": true
				},
				"responses": {
					"201": {
						"description": "Domain successfully added to the blacklist",
						"content": {
							"application/json": {
								"schema": { "$ref": "#/components/schemas/BlacklistResponse" }
							}
						}
					},
					"401": {
						"description": "Missing or invalid authentication credentials"
					},
					"422": { "description": "Validation error in request payload" }
				},
				"security": [{ "OAuth2PasswordBearer": [] }]
			}
		},
		"/api/blacklist/{domain_id}": {
			"delete": {
				"tags": ["Blacklisted Domains"],
				"summary": "Remove a domain from the blacklist",
				"description": "Deletes a specific blacklist entry if it belongs to the current user.",
				"operationId": "remove_from_blacklist_api_blacklist__domain_id__delete",
				"security": [{ "OAuth2PasswordBearer": [] }],
				"parameters": [
					{
						"name": "domain_id",
						"in": "path",
						"required": true,
						"schema": {
							"type": "string",
							"format": "uuid",
							"title": "Domain Id"
						}
					}
				],
				"responses": {
					"204": {
						"description": "Domain successfully removed from the blacklist"
					},
					"401": {
						"description": "Missing or invalid authentication credentials"
					},
					"404": {
						"description": "Domain not found or does not belong to the current user"
					},
					"422": {
						"description": "Validation Error",
						"content": {
							"application/json": {
								"schema": { "$ref": "#/components/schemas/HTTPValidationError" }
							}
						}
					}
				}
			}
		},
		"/api/suppliers/": {
			"post": {
				"tags": ["Suppliers"],
				"summary": "Manually create/register a new supplier (optionally attach to a request)",
				"description": "Creates a new supplier (or reuses existing domain).\n\nIf request_id provided: attach by creating RequestSupplier (pending).\nDup domain: 409 only if no request_id (preserves explicit create).\nWith request_id, existing suppliers are reused+attached for the\nfrontend \"add to current request\" flow.",
				"operationId": "create_supplier_api_suppliers__post",
				"requestBody": {
					"content": {
						"application/json": {
							"schema": { "$ref": "#/components/schemas/SupplierCreate" }
						}
					},
					"required": true
				},
				"responses": {
					"201": {
						"description": "New supplier created (and attached to request if request_id provided)",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/app__api__suppliers__schemas__SupplierResponse"
								}
							}
						}
					},
					"200": {
						"description": "Existing supplier reused and attached to the provided request"
					},
					"401": {
						"description": "Missing or invalid authentication credentials"
					},
					"404": {
						"description": "Request not found or does not belong to current user"
					},
					"409": {
						"description": "Supplier with this domain already exists (when called without request_id)"
					},
					"422": { "description": "Validation error in request payload" }
				},
				"security": [{ "OAuth2PasswordBearer": [] }]
			}
		},
		"/api/history/": {
			"get": {
				"tags": ["Search history"],
				"summary": "Retrieve search history for the current user",
				"description": "Returns all search history entries belonging to the current user, ordered by creation time.",
				"operationId": "get_search_history_api_history__get",
				"responses": {
					"200": {
						"description": "List of past searches performed by the authenticated user",
						"content": {
							"application/json": {
								"schema": {
									"items": {
										"$ref": "#/components/schemas/SearchHistoryResponse"
									},
									"type": "array",
									"title": "Response Get Search History Api History  Get"
								}
							}
						}
					},
					"401": {
						"description": "Missing or invalid authentication credentials"
					}
				},
				"security": [{ "OAuth2PasswordBearer": [] }]
			}
		},
		"/api/": {
			"get": {
				"summary": "Root",
				"operationId": "root_api__get",
				"responses": {
					"200": {
						"description": "Successful Response",
						"content": { "application/json": { "schema": {} } }
					}
				}
			}
		},
		"/api/health": {
			"get": {
				"summary": "Health",
				"operationId": "health_api_health_get",
				"responses": {
					"200": {
						"description": "Successful Response",
						"content": {
							"application/json": {
								"schema": {
									"additionalProperties": true,
									"type": "object",
									"title": "Response Health Api Health Get"
								}
							}
						}
					}
				}
			}
		}
	},
	"components": {
		"schemas": {
			"Attachment": {
				"properties": {
					"filename": {
						"type": "string",
						"title": "Filename",
						"description": "Original filename of the attachment",
						"examples": ["quote.pdf"]
					},
					"content_type": {
						"anyOf": [{ "type": "string" }, { "type": "null" }],
						"title": "Content Type",
						"description": "MIME type of the file",
						"examples": ["application/pdf"]
					},
					"size": {
						"anyOf": [{ "type": "integer" }, { "type": "null" }],
						"title": "Size",
						"description": "File size in bytes",
						"examples": [245678]
					},
					"path": {
						"anyOf": [{ "type": "string" }, { "type": "null" }],
						"title": "Path",
						"description": "Server path where the file is stored",
						"examples": ["/uploads/attachments/quote.pdf"]
					}
				},
				"type": "object",
				"required": ["filename", "content_type", "size", "path"],
				"title": "Attachment",
				"description": "Email attachment metadata."
			},
			"BlacklistCreate": {
				"properties": {
					"domain": {
						"type": "string",
						"maxLength": 255,
						"minLength": 3,
						"title": "Domain",
						"description": "Domain name to blacklist (will be lowercased and stripped)",
						"examples": ["example.com"]
					},
					"reason": {
						"anyOf": [
							{ "type": "string", "maxLength": 500 },
							{ "type": "null" }
						],
						"title": "Reason",
						"description": "Optional reason for blacklisting the domain",
						"examples": ["Spam source"]
					}
				},
				"type": "object",
				"required": ["domain"],
				"title": "BlacklistCreate",

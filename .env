# ====================================

# Автоматическая проверка email каждые 2 минуты (true/false)
# Установите false для отключения во время разработки
ENABLE_EMAIL_CHECKING=true
# настройка получения емайлов 

ATTACHMENT_CACHE_MAX_SIZE=1000          # Максимальное количество записей в кеше
ATTACHMENT_CACHE_TTL=86400000           # TTL кеша в миллисекундах (24 часа)
ATTACHMENT_CACHE_ENABLED=true           # Включить/выключить кеш

# Настройки batch операций
ATTACHMENT_BATCH_SIZE=10                # Размер batch для операций с БД

# Настройки мониторинга
ATTACHMENT_MONITORING_ENABLED=true      # Включить мониторинг
ATTACHMENT_MONITORING_INTERVAL=300000   # Интервал мониторинга (5 минут)

# Настройки обработки
ATTACHMENT_PROCESSING_TIMEOUT=60000     # Таймаут обработки (60 сек)
ATTACHMENT_MAX_FILE_SIZE=52428800       # Максимальный размер файла (50MB)
ATTACHMENT_RETRY_COUNT=3                # Количество повторов при ошибке



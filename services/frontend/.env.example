# Public API path for the browser (must be same-origin HTTPS in production).
# Do NOT use http://IP:port here when the site is served over HTTPS.
API_BASE=/api

# Runtime proxy target for Nitro (Docker service name or localhost).
NUXT_BACKEND_INTERNAL_URL=http://127.0.0.1:8000

MAX_UPLOAD_FILES=2
MAX_UPLOAD_SIZE=10485760
MAX_TZ_UPLOAD_SIZE=104857600
